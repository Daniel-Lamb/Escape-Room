---
import '../styles/global.css';
import HelloIsland from '../components/HelloIsland.tsx';

// Phase 0 smoke test: proves the Astro build renders a real page and that the
// React + Tailwind integrations compile and hydrate. The dashboard homepage is
// still served verbatim from public/index.html; this route only confirms the
// framework is wired up. BASE_URL keeps links correct under both '/' (Vercel)
// and '/Escape-Room/' (GitHub Pages).
const base = import.meta.env.BASE_URL;
const rooms = ['pilgrims-road', 'starfall-station', 'wild-court', 'gate-of-life'];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Astro check — Escape Room</title>
  </head>
  <body class="mx-auto max-w-2xl px-4 py-16 font-sans text-neutral-200 bg-neutral-950 min-h-screen">
    <h1 class="text-2xl font-bold text-orange-400">Astro is running ✅</h1>
    <p class="mt-2">Phase 0 scaffold is live. The dashboard is served verbatim at <a class="text-orange-300 underline" href={base}>/</a>.</p>
    <p class="mt-4">Games detected in <code class="text-orange-300">public/</code>:</p>
    <ul class="mt-1 list-disc pl-6">
      {rooms.map((id) => (
        <li><a class="text-orange-300 underline" href={`${base}${id}/`}>{id}</a></li>
      ))}
    </ul>
    <p class="mt-6">React + Tailwind check:</p>
    <div class="mt-1"><HelloIsland client:load /></div>
  </body>
</html>
